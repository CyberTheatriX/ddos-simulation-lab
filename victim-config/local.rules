# Custom HTTP Flood Rules for Suricata Lab

# Rule 1: Always‑alert (fires on every HTTP request to victim)
alert http any any -> 192.168.56.12 any \
    (msg:"Custom HTTP Flood Detected"; \
    flow:to_server; \
    classtype:attempted-dos; \
    sid:1000002; rev:1; \
    priority:2;)

# Rule 2: Thresholded (fires only if >100 requests in 10 seconds from same source)
alert http any any -> 192.168.56.12 any \
    (msg:"Custom HTTP Flood Threshold Exceeded"; \
    flow:to_server; \
    classtype:attempted-dos; \
    sid:1000003; rev:1; \
    priority:2; \
    threshold:type both, track by_src, count 100, seconds 10;)

